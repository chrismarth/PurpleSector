
// Prisma schema for Purple Sector telemetry database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @db.Uuid
  name            String
  description     String?
  location        String?
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions        Session[]
  runPlans        RunPlan[]
  
  @@index([createdAt])
  @@index([userId])
}

model Session {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String   @db.Uuid
  eventId                 String   @db.Uuid
  name                    String
  source                  String   // "live" | "demo"
  status                  String   @default("active") // "active" | "paused" | "archived"
  started                 Boolean  @default(false) // Whether telemetry collection has been started
  readAccess              String   @default("PRIVATE")
  readAccessOrgId         String?
  tags                    String?  // JSON array of session tags
  plotConfigs             String?  // JSON array of plot configurations
  vehicleId               String?  @db.Uuid
  vehicleConfigurationId  String?  @db.Uuid
  vehicleSetupId          String?  @db.Uuid
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event                   Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vehicle                 Vehicle?              @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  vehicleConfiguration    VehicleConfiguration? @relation(fields: [vehicleConfigurationId], references: [id], onDelete: SetNull)
  vehicleSetup            VehicleSetup?         @relation(fields: [vehicleSetupId], references: [id], onDelete: SetNull)
  laps                    Lap[]
  runPlanItems            RunPlanItem[]
  
  @@index([eventId])
  @@index([userId])
  @@index([vehicleId])
  @@index([createdAt])
}

model RunPlan {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  eventId     String?  @db.Uuid
  name        String
  description String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  items       RunPlanItem[]

  @@index([userId])
  @@index([eventId])
}

model RunPlanItem {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runPlanId               String   @db.Uuid
  order                   Int
  sessionName             String
  vehicleId               String?  @db.Uuid
  vehicleConfigurationId  String?  @db.Uuid
  vehicleSetupId          String?  @db.Uuid
  notes                   String?
  sessionId               String?  @db.Uuid @unique
  status                  String   @default("planned")
  createdAt               DateTime @default(now())
  runPlan                 RunPlan              @relation(fields: [runPlanId], references: [id], onDelete: Cascade)
  vehicle                 Vehicle?             @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  vehicleConfiguration    VehicleConfiguration? @relation(fields: [vehicleConfigurationId], references: [id], onDelete: SetNull)
  vehicleSetup            VehicleSetup?        @relation(fields: [vehicleSetupId], references: [id], onDelete: SetNull)
  session                 Session?             @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([runPlanId, order])
}

model Lap {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId       String   @db.Uuid  @map("session_id")
  lapNumber       Int                @map("lap_number")
  lapTime         Float?             @map("lap_time") // in seconds
  analyzed        Boolean  @default(false)
  suggestions     String?  // JSON array of AI suggestions
  driverComments  String?  @map("driver_comments") // Driver's notes about the lap
  tags            String?  // JSON array of tags
  plotConfigs     String?  @map("plot_configs") // JSON array of plot configurations
  createdAt       DateTime @default(now())
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  chatMessages    ChatMessage[]

  @@unique([sessionId, lapNumber])
  @@index([sessionId, lapNumber])
  @@map("laps")
}

model SavedAnalysisLayout {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  name        String
  description String?
  // JSON blob describing analysis panel instances and grid options
  layout      String
  // Arbitrary string context, e.g. "lap:<lapId>", "session:<sessionId>", "global:live"
  context     String   @default("global") // "global" | "session" | "lap"
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([context, isDefault])
  @@index([createdAt])
  @@index([userId])
}

model Vehicle {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String                 @db.Uuid
  name                  String
  description           String?
  inServiceDate         DateTime?
  outOfServiceDate      DateTime?
  tags                  String?                // JSON array of tags
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  configurations        VehicleConfiguration[]
  setups                VehicleSetup[]
  sessions              Session[]
  runPlanItems          RunPlanItem[]

  @@index([createdAt])
  @@index([userId])
}

model VehicleConfiguration {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @db.Uuid
  vehicleId       String   @db.Uuid
  name            String
  description     String?
  parts           String   // JSON object of parts (e.g., {"frontWing": "High Downforce", "rearWing": "Medium", ...})
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  setups          VehicleSetup[]
  sessions        Session[]
  runPlanItems    RunPlanItem[]

  @@index([vehicleId])
  @@index([createdAt])
  @@index([userId])
}

model VehicleSetup {
  id                      String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String                @db.Uuid
  vehicleId               String                @db.Uuid
  vehicleConfigurationId  String?               @db.Uuid
  name                    String
  description             String?
  parameters              String                // JSON object of setup parameters (e.g., {"weightDistribution": "52/48", "rideHeight": "50mm", ...})
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  user                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle                 Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vehicleConfiguration    VehicleConfiguration? @relation(fields: [vehicleConfigurationId], references: [id], onDelete: SetNull)
  sessions                Session[]
  runPlanItems            RunPlanItem[]

  @@index([vehicleId])
  @@index([vehicleConfigurationId])
  @@index([createdAt])
  @@index([userId])
}

model MathChannel {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  label       String
  unit        String
  expression  String   // mathjs expression
  inputs      String   // JSON array of MathChannelInput[] with channelId and alias
  validated   Boolean  @default(false) // Whether the expression has been validated
  comment     String?  // Optional description/documentation for the channel
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([createdAt])
  @@index([userId])
}

model User {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username        String   @unique
  fullName        String
  avatarUrl       String?  // URL or path to the user's avatar image
  role            String   // "ORG_ADMIN" | "USER" (stubbed for now)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  settings        UserSettings?
  events          Event[]
  sessions        Session[]
  vehicles        Vehicle[]
  vehicleConfigurations VehicleConfiguration[]
  vehicleSetups    VehicleSetup[]
  analysisLayouts SavedAnalysisLayout[]
  mathChannels    MathChannel[]
  chatMessages    ChatMessage[]
  apiTokens       ApiToken[]
  orgMemberships  OrganizationMember[]
  groupMemberships GroupMember[]
  agentConversations AgentConversation[]
  runPlans        RunPlan[]
}

model UserSettings {
  userId    String  @id @db.Uuid
  theme     String? // "light" | "dark"
  data      String? // JSON blob for additional settings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   OrganizationMember[]
  groups    Group[]
}

model OrganizationMember {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  userId         String   @db.Uuid
  role           String   // "ADMIN" | "MEMBER"
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Group {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        GroupMember[]

  @@index([organizationId])
}

model GroupMember {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId String @db.Uuid
  userId  String @db.Uuid
  createdAt DateTime @default(now())
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

model ApiToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  name        String
  tokenHash   String   @unique
  scopes      String?  // JSON array of scope strings
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revokedAt])
}
