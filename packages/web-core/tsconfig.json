{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@purplesector/plugin-api": ["../plugin-api/src"],
      "@purplesector/plugin-agent": ["../plugin-agent/src"],
      "@purplesector/web-charts": ["../web-charts/src"],
      "@purplesector/plugin-core-lap-telemetry": ["../plugin-core-lap-telemetry/src"],
      "@purplesector/plugin-vehicles": ["../plugin-vehicles/src"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
