{
  "name": "purple-sector",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev:vite": "vite --config packages/web-core/vite.config.ts",
    "build:vite": "vite build --config packages/web-core/vite.config.ts",
    "typecheck:web": "tsc -p packages/web-core/tsconfig.json --noEmit",
    "dev:desktop": "nx serve desktop",
    "build:desktop": "nx build desktop",
    "generate:demo-telemetry": "node scripts/generate-demo-telemetry.js",
    "dev:api": "cd apps/web && .venv/bin/uvicorn purplesector.asgi:application --host 0.0.0.0 --port 8000 --reload",
    "api:migrate": "cd apps/web && .venv/bin/python manage.py migrate --run-syncdb",
    "api:setup": "cd apps/web && uv venv && uv pip install -e '.[ai]'",
    "dev:start": "./scripts/start-dev.sh",
    "dev:stop": "./scripts/stop-dev.sh",
    "dev:stop-all": "./scripts/stop-dev.sh",
    "db:reset": "./scripts/reset-db.sh",
    "db:check": "python3 scripts/check-db-health.py",
    "generate-demo": "node scripts/generate-demo-telemetry.js",
    "demo:replay": "./scripts/run-demo-replay.sh",
    "proto:generate": "pbjs -t static-module -w es6 -o packages/web-core/src/proto/telemetry.js packages/proto/telemetry.proto && pbts -o packages/web-core/src/proto/telemetry.d.ts packages/web-core/src/proto/telemetry.js",
    "test:protobuf": "node scripts/test-protobuf.js",
    "test:ws-protobuf": "node scripts/test-websocket-protobuf.js",
    "setup": "npm install && npm run api:migrate && npm run generate-demo",
    "telemetry-server": "node apps/mcp-telemetry/telemetry-server.ts",
    "analysis-server": "node apps/mcp-analysis/analysis-server.ts",
    "docs:dev": "docusaurus start apps/docs-site",
    "docs:build": "docusaurus build apps/docs-site",
    "docs:serve": "docusaurus serve apps/docs-site/build",
    "docs:deploy": "docusaurus build apps/docs-site && gh-pages -d apps/docs-site/build -b gh-pages",
    "docs:publish": "npm run docs:deploy"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@inertiajs/react": "^2.3.21",
    "@monaco-editor/react": "^4.7.0",
    "@purplesector/plugin-agent": "file:packages/plugin-agent",
    "@purplesector/plugin-api": "file:packages/plugin-api",
    "@purplesector/plugin-core-lap-telemetry": "file:packages/plugin-core-lap-telemetry",
    "@purplesector/proto": "file:packages/proto",
    "@purplesector/web-charts": "file:packages/web-charts",
    "@purplesector/web-core": "file:packages/web-core",
    "@purplesector/web-telemetry": "file:packages/web-telemetry",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.59.20",
    "@tauri-apps/api": "^2.0.0",
    "@use-gesture/react": "^10.3.1",
    "acc-node-wrapper": "^1.0.6",
    "ai": "^3.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.400.0",
    "mathjs": "^11.11.0",
    "mcp-handler": "^1.0.7",
    "openai": "^4.52.0",
    "pg": "8.18.0",
    "protobufjs": "^7.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.6",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "trino-client": "^0.2.9",
    "uplot": "^1.6.32",
    "uplot-react": "^1.2.4",
    "ws": "^8.17.1",
    "zod": "^3.25.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@docusaurus/core": "^3.5.2",
    "@docusaurus/preset-classic": "^3.5.2",
    "@docusaurus/theme-classic": "^3.5.2",
    "@docusaurus/types": "^3.5.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/cli": "^2.9.5",
    "@types/node": "^20.14.10",
    "@types/pg": "8.16.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "gh-pages": "^6.0.0",
    "nx": "22.1.2",
    "pm2": "^6.0.13",
    "postcss": "^8.4.39",
    "protobufjs-cli": "^1.1.3",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.20.6",
    "typescript": "^5.5.3",
    "vite": "^8.0.8"
  },
  "nx": {}
}
