# OpenAI API Key for AI analysis
OPENAI_API_KEY=sk-your-openai-api-key-here

# Database
DATABASE_URL="file:./dev.db"

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=purple-sector
KAFKA_TOPIC_TELEMETRY=telemetry
KAFKA_TOPIC_COMMANDS=commands
KAFKA_CONSUMER_GROUP=telemetry-processors

# WebSocket Server
WS_PORT=8080
WS_HOST=0.0.0.0
WS_PING_INTERVAL=30000
WS_MAX_PAYLOAD=10485760

# Telemetry Collector
TELEMETRY_UDP_PORT=9996
TELEMETRY_UDP_HOST=0.0.0.0

# ACC Configuration
ACC_UDP_PORT=9000
ACC_UDP_HOST=0.0.0.0
ACC_HOST=127.0.0.1
ACC_BROADCAST_PORT=9000
ACC_DISPLAY_NAME=PurpleSector
ACC_PASSWORD=
ACC_UPDATE_INTERVAL=100

# AC Configuration
AC_SM_INTERVAL=16

# Logging
LOG_LEVEL=info
LOG_FORMAT=simple
SERVICE_NAME=purple-sector

# Protobuf
PROTOBUF_ENABLED=true

# ── Cloud Pipeline (docker-compose.dev.yml) ───────────────────────────

# Redpanda (Kafka-compatible message buffer)
REDPANDA_BROKERS=localhost:9092
REDPANDA_SCHEMA_REGISTRY=http://localhost:8081

# RisingWave (stream processing)
RISINGWAVE_HOST=localhost
RISINGWAVE_PORT=4566

# Redis (live telemetry state)
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_TELEMETRY=purplesector-telemetry
MINIO_BUCKET_ICEBERG=purplesector-iceberg

# Trino (semantic query layer)
TRINO_URL=http://localhost:8080
QUERY_ENGINE_URL=http://localhost:8080

# Postgres (app metadata DB — cloud mode)
# DATABASE_URL="postgresql://purplesector:devpassword@localhost:5432/purplesector"

# gRPC Gateway
GRPC_GATEWAY_URL=http://localhost:50051
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=telemetry-batches

# Authentication (gRPC Gateway)
AUTH_DISABLED=true
# AUTH_ISSUER_URL=https://purplesector.us.auth0.com/
# AUTH_AUDIENCE=https://api.purplesector.io
# AUTH_JWKS_URL=

# Redis WebSocket Server
# WS_PORT=8080  (already defined above)
BACKFILL_COUNT=1000
POLL_INTERVAL_MS=50
